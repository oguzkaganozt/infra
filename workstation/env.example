# Minimal secrets to store in Infisical.

TS_AUTHKEY='<tailscale-auth-key>'
RCLONE_CONFIG_B64='<base64-encoded-rclone.conf>'
RCLONE_REMOTE='gdrive'
WORKSTATION_PASSWORD='<strong-nomachine-password>'

# Optional overrides only if you want to change defaults.
# WORKSTATION_ROLE='workstation' # or 'sync-node'
# TS_HOSTNAME='gpu-workstation'
# WORKSTATION_USER='workstation'
# GITHUB_TOKEN='<github-token>'
# WORKSPACE_DIR='/workspace'
# DRIVE_DIR='/drive'
# SYNCTHING_PEER_DEVICE_IDS='<comma-separated-peer-device-ids>'
# SYNCTHING_PEER_NAME='sync-node'
# SYNCTHING_PEER_ADDRESS='dynamic'
# SYNCTHING_FOLDER_ID='workspace'
# RCLONE_REMOTE_PATH=''
