[Unit]
Description=Back up workstation workspace before shutdown
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=/etc/workstation.env
ExecStart=/bin/true
ExecStop=/usr/local/bin/backup-workspace
TimeoutStopSec=30min

[Install]
WantedBy=multi-user.target
